{
  "manifest_version": 3,
  "name": "UTC Survey Helper",
  "description": "Auto fill UTC survey",
  "version": "1.0.0",

  "permissions": ["storage", "tabs", "activeTab"],

  "host_permissions": ["*://sis.utc.edu.vn/*"],

  "background": {
    "service_worker": "background/background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://sis.utc.edu.vn/survey/*"],
      "js": [
        "content/storage.js",
        "content/strategy.js",
        "content/autofill.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
